# Database Configuration
# Neon Postgres or local PostgreSQL URL (e.g. postgresql://user:pass@localhost:5432/dbname)
DATABASE_URL=postgres://your_neon_db_url_here

# JWT authentication configuration
JWT_SECRET=super-secret-jwt-key-change-this-in-production

# Email Service Configuration (Optional, falls back to terminal console logs if left empty)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="ichat Secure" <noreply@example.com>

# Server Port
PORT=3000
